# Configuração do Servidor
PORT=3000
NODE_ENV=development

# Sessão (use um valor aleatório em produção)
SESSION_SECRET=sua-chave-secreta-aqui-mude-em-producao

# Google OAuth (OBRIGATÓRIO para login com Google)
# Obtenha em: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=seu-client-id-aqui.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu-secret-aqui
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Em produção no Render, use:
# GOOGLE_CALLBACK_URL=https://seu-app.onrender.com/auth/google/callback

# Banco de dados SQLite
DB_PATH=./compras_ai.db

# URL base do app (em produção no Render)
# APP_URL=https://seu-app.onrender.com
